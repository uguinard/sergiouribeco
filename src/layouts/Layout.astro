---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const { title, description = 'Ecosistema Digital de Sergio Uribe', lang = 'en' } = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Sergio Uribe</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=Lora:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
  </head>
  <body class="min-h-screen text-ink bg-sand font-serif selection:bg-earth selection:text-paper">
    <div class="max-w-5xl mx-auto px-6 md:px-12 py-8 md:py-16">
      <nav class="mb-10 md:mb-20 flex justify-between items-center font-sans text-sm tracking-wide text-ink-light">
        <a href={`/${lang === 'en' ? '' : lang}`} class="hover:text-ink transition-colors duration-300">
          Sergio Uribe
        </a>
        <div class="flex gap-4 md:gap-6 flex-wrap justify-end">
          <a href={`/${lang === 'en' ? '' : lang + '/'}geography`} class="hover:text-ink transition-colors duration-300">Geography</a>
          <a href={`/${lang === 'en' ? '' : lang + '/'}garden`} class="hover:text-ink transition-colors duration-300">Garden</a>
          <a href={`/${lang === 'en' ? '' : lang + '/'}philosophy`} class="hover:text-ink transition-colors duration-300">Philosophy</a>
          <a href={`/${lang === 'en' ? '' : lang + '/'}cv`} class="hover:text-ink transition-colors duration-300">CV</a>
          <div class="h-4 w-[1px] bg-earth opacity-30 mx-2 hidden md:block"></div>
          <a href={lang === 'en' ? `/es${Astro.url.pathname}` : Astro.url.pathname.replace(/^\/es/, '') || '/'} class="hover:text-ink transition-colors duration-300 text-earth">
            {lang === 'en' ? 'ES' : 'EN'}
          </a>
        </div>
      </nav>
      
      <main class="animate-fade-in-up">
        <slot />
      </main>
      
      <footer class="mt-32 pt-12 border-t border-earth/20 font-sans text-xs text-ink-light flex justify-between">
        <p>&copy; {new Date().getFullYear()} Sergio Uribe. All rights reserved.</p>
        <p>A humanist digital ecosystem.</p>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-in-up {
    animation: fadeInUp 0.8s ease-out forwards;
  }
</style>
