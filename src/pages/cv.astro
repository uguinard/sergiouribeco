---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Curriculum Vitae">
  <div class="max-w-3xl mx-auto mt-8">
    <header class="mb-16 border-b border-earth/20 pb-12">
      <h1 class="text-4xl md:text-5xl font-serif text-ink tracking-tight mb-2">Sergio Uribe</h1>
      <p class="text-xl text-ink-light font-sans tracking-wide uppercase mb-6 text-sm">Pedagogical Engineer & Spanish Acquisition Specialist</p>
      
      <div class="flex gap-4 font-sans text-xs text-ink/70">
        <a href="mailto:hello@sergiouribe.co" class="hover:text-clay transition-colors">hello@sergiouribe.co</a>
        <span>&bull;</span>
        <a href="https://linkedin.com/in/sergiouribe" target="_blank" class="hover:text-clay transition-colors">LinkedIn</a>
      </div>
    </header>

    <div class="space-y-16">
      <section>
        <h2 class="text-xs font-sans uppercase tracking-widest text-earth mb-8 flex items-center gap-4">
          <span class="h-[1px] w-8 bg-earth"></span> Profile
        </h2>
        <p class="font-serif text-ink-light leading-relaxed">
          Specialist in Spanish language acquisition with a strong focus on 4E Cognition and Comprehensible Input. I design human-centric linguistic environments mapping theoretical cognitive frameworks into practical, immersive experiences for learners worldwide.
        </p>
      </section>

      <section>
        <h2 class="text-xs font-sans uppercase tracking-widest text-earth mb-8 flex items-center gap-4">
          <span class="h-[1px] w-8 bg-earth"></span> Experience
        </h2>
        
        <div class="space-y-12">
          <!-- Experience Item -->
          <div class="relative pl-6 border-l border-ink/10 hover:border-clay transition-colors duration-300">
            <div class="absolute -left-[5px] top-1.5 w-2 h-2 rounded-full bg-sand border-2 border-clay"></div>
            <div class="flex justify-between items-start mb-2">
              <h3 class="font-serif text-xl text-ink">Independent Pedagogical Engineer</h3>
              <span class="text-xs font-sans text-ink/50 uppercase tracking-wider">2023 &mdash; Present</span>
            </div>
            <p class="text-sm font-sans text-ink-light mb-3">Self-Employed</p>
            <p class="font-serif text-ink-light leading-relaxed">
              Designing curricula and immersive platforms for Spanish acquisition. Utilizing interactive media, comprehensible input strategies, and cognitive linguistics to facilitate organic language growth.
            </p>
          </div>
          
          <!-- Experience Item -->
          <div class="relative pl-6 border-l border-ink/10 hover:border-earth transition-colors duration-300">
            <div class="absolute -left-[5px] top-1.5 w-2 h-2 rounded-full bg-sand border-2 border-ink/20"></div>
            <div class="flex justify-between items-start mb-2">
              <h3 class="font-serif text-xl text-ink">Language Instructor & Curriculum Designer</h3>
              <span class="text-xs font-sans text-ink/50 uppercase tracking-wider">2019 &mdash; 2023</span>
            </div>
            <p class="text-sm font-sans text-ink-light mb-3">Various Institutes</p>
            <p class="font-serif text-ink-light leading-relaxed">
              Applied Comprehensible Input principles in practical classroom environments, transitioning traditional grammar-first syllabi into message-first acquisition environments.
            </p>
          </div>
        </div>
      </section>

      <section>
        <h2 class="text-xs font-sans uppercase tracking-widest text-earth mb-8 flex items-center gap-4">
          <span class="h-[1px] w-8 bg-earth"></span> Education
        </h2>
        
        <div class="space-y-8">
          <div class="flex justify-between items-start">
             <div>
               <h3 class="font-serif text-lg text-ink">M.A. in Applied Linguistics</h3>
               <p class="text-sm font-sans text-ink-light">Focus on Cognitive Linguistics and 4E approaches</p>
             </div>
             <span class="text-xs font-sans text-ink/50 uppercase tracking-wider">2022</span>
          </div>
        </div>
      </section>
    </div>
  </div>
</Layout>
